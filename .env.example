# ============================================================
# Travel Connect Pro — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real keys.
# ============================================================

# ─── SUPABASE ─────────────────────────────────────────────
# Project: pjyjblllcllnqsjbvbfc
# Dashboard: https://supabase.com/dashboard/project/pjyjblllcllnqsjbvbfc

NEXT_PUBLIC_SUPABASE_URL=https://pjyjblllcllnqsjbvbfc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Settings > API > anon public
SUPABASE_SERVICE_ROLE_KEY=              # Settings > API > service_role SECRET — server-only!
SUPABASE_JWT_SECRET=                    # Settings > API > JWT secret — server-only!

# Used by Supabase CLI for db push / gen types
SUPABASE_ACCESS_TOKEN=                  # https://supabase.com/dashboard/account/tokens

# ─── TELEGRAM ─────────────────────────────────────────────
# One bot token per deployment; chat IDs stored per-hotel in DB
TELEGRAM_BOT_TOKEN=                     # @BotFather > /newbot > token

# ─── EXTERNAL APIs ───────────────────────────────────────
OPENWEATHER_API_KEY=                    # openweathermap.org
AVIATION_STACK_API_KEY=                 # aviationstack.com
EXCHANGE_RATE_API_KEY=                  # exchangerate-api.com or NBG direct

# ─── APP URLS ────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000
NEXT_PUBLIC_DISPLAY_URL=http://localhost:3001
NEXT_PUBLIC_PWA_URL=http://localhost:3002

# ─── ANALYTICS SALT (rotates daily via pg_cron) ──────────
# Never stored client-side; Edge Function reads from Vault in production.
# For local dev, a static salt is fine.
DEVICE_HASH_SALT=change-me-to-random-32-chars
